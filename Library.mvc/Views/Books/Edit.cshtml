@model Library.Domain.Entities.Book

@{
    ViewData["Title"] = "Edit Book";
}

<h1>Edit Book</h1>

<form method="post" asp-action="Edit" asp-route-bookId="@Model.Id">
    
    <!-- Campo que guarda o Id do livro -->
    <input type="hidden" asp-for="Id"/>

    <!-- Campo Título -->
    <div class="mb-3">
        <label asp-for="Title" class="form-label">Title</label>
        <input asp-for="Title" class="form-control"/>
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <!-- Campo Autor -->
    <div class="mb-3">
        <label asp-for="Author" class="form-label">Author</label>
        <input asp-for="Author" class="form-control"/>
        <span asp-validation-for="Author" class="text-danger"></span>
    </div>

    <!-- Campo ISBN -->
    <div class="mb-3">
        <label asp-for="Isbn" class="form-label">ISBN</label>
        <input asp-for="Isbn" class="form-control"/>
        <span asp-validation-for="Isbn" class="text-danger"></span>
    </div>

    <!-- Campo Categoria -->
    <div class="mb-3">
        <label asp-for="Category" class="form-label">Category</label>
        <select asp-for="Category" class="form-select">
            @foreach (var category in (IEnumerable<Library.Domain.Enums.BookCategory>)ViewData["CategoryList"])
            {
                <option value="@category">@category</option>
            }
        </select>
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>

    <!-- Botões -->
    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>

</form>