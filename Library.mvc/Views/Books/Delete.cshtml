@model Library.Domain.Entities.Book

@{
    ViewData["Title"] = "Delete Book";
}

<h1>Delete Book</h1>

<p class="text-danger">Are you sure you want to delete this book?</p>

<!-- Exibe os dados do livro antes de confirmar a deleção -->
<table class="table">
    <tr>
        <th>Title</th>
        <td>@Model.Title</td>
    </tr>
    <tr>
        <th>Author</th>
        <td>@Model.Author</td>
    </tr>
    <tr>
        <th>ISBN</th>
        <td>@Model.Isbn</td>
    </tr>
    <tr>
        <th>Category</th>
        <td>@Model.Category</td>
    </tr>
    <tr>
        <th>Available</th>
        <td>@(Model.IsAvailable ? "Yes" : "No")</td>
    </tr>
</table>

<!-- Botões de confirmação e cancelamento -->
<form method="post" asp-action="Delete" asp-route-bookId="@Model.Id">
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>