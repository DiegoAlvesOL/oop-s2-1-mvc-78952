@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Role Management";
}

<h1>Role Management</h1>

<!-- Formulário para criar nova role -->
<form method="post" asp-action="CreateRole" asp-controller="Admin" class="mb-4">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="newRoleName" placeholder="New role name..." class="form-control"/>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Create Role</button>
        </div>
    </div>
</form>

<!-- Tabela de roles -->
<table class="table table-striped">
    <thead>
    <tr>
        <th>Role Name</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var role in Model)
    {
        <tr>
            <td>@role.Name</td>
            <td>
                <form method="post" asp-action="DeleteRole" asp-controller="Admin">
                    <input type="hidden" name="roleId" value="@role.Id"/>
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>