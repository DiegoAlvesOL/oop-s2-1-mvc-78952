@model Library.Domain.Entities.Member

@{
    ViewData["Title"] = "Delete Member";
}

<h1>Delete Member</h1>

<p class="text-danger">Are you sure you want to delete this member?</p>

<!-- Exibe os dados do membro antes de confirmar a deleção -->
<table class="table">
    <tr>
        <th>Full Name</th>
        <td>@Model.FullName</td>
    </tr>
    <tr>
        <th>Email</th>
        <td>@Model.Email</td>
    </tr>
    <tr>
        <th>Phone Number</th>
        <td>@Model.PhoneNumber</td>
    </tr>
</table>

<!-- Botões de confirmação e cancelamento -->
<form method="post" asp-action="Delete" asp-route-memberId="@Model.Id">
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>